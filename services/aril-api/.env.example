# ARIL API — local development
ARIL_ENV=development
ARIL_HOST=127.0.0.1
ARIL_PORT=8741
ARIL_LOG_LEVEL=info

# Primary provider — OpenRouter (recommended)
# Create a key at https://openrouter.ai/keys (sk-or-v1-…)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/fizzball/ARIL
OPENROUTER_APP_NAME=ARIL

# Optional direct providers (not used when OpenRouter is set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Defaults
ARIL_DEFAULT_TEMPERATURE=0.7
ARIL_CACHE_TOKEN_THRESHOLD=1024
ARIL_REWRITE_MODEL=openai/gpt-4.1-mini
ARIL_COMPARE_MODEL_COUNT=2
