# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prefer HTTPS canonical host (apex)
RewriteCond %{HTTP_HOST} ^www\.aril\.host$ [NC]
RewriteRule ^ https://aril.host%{REQUEST_URI} [L,R=301]

# DMG downloads
<FilesMatch "\.(dmg)$">
  Header set Content-Type "application/octet-stream"
  Header set Content-Disposition "attachment"
</FilesMatch>

# Cache static assets; always revalidate HTML and download metadata
<Files "index.html">
  Header set Cache-Control "no-cache, must-revalidate"
</Files>

<Files "robots.txt">
  Header set Cache-Control "public, max-age=3600, must-revalidate"
  Header set Content-Type "text/plain; charset=UTF-8"
</Files>

<Files "sitemap.xml">
  Header set Cache-Control "public, max-age=3600, must-revalidate"
  Header set Content-Type "application/xml; charset=UTF-8"
</Files>

<FilesMatch "\.(css|png|jpg|webp|svg)$">
  Header set Cache-Control "public, max-age=3600, must-revalidate"
</FilesMatch>

<Files "latest.json">
  Header set Cache-Control "no-cache"
</Files>

# Light SEO / security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
